"""
gui/app.py
==========
Streamlit 3-panel Trade Manager UI.

Layout
------
  LEFT   — Expandable tree: Traders → Books → Trades
  MIDDLE — Editable AgGrid of trades in the selected book
  RIGHT  — Trade header editor + per-leg editable expanders

Run
---
  cd PySpark/examples/gui && streamlit run app.py --server.port 8502
"""

from __future__ import annotations

import json
import sys
from datetime import date
from pathlib import Path
from typing import Any, Dict, List, Optional

# ── path setup ────────────────────────────────────────────────────────────────
_HERE     = Path(__file__).resolve().parent
_EXAMPLES = _HERE.parent
_PROJECT  = _EXAMPLES.parent

for _p in [str(_EXAMPLES), str(_PROJECT)]:
    if _p not in sys.path:
        sys.path.insert(0, _p)

import streamlit as st
import pandas as pd
from st_aggrid import AgGrid, GridOptionsBuilder, GridUpdateMode, DataReturnMode

from db.repository import TradeRepository
from models.enums import TradeDirection

# ── constants ─────────────────────────────────────────────────────────────────
DB_PATH    = str(_PROJECT / "trades.db")
DIRECTIONS = [d.value for d in TradeDirection]
MAX_TRADES_IN_TREE = 50   # per book in left tree

LEG_ICONS = {
    "FIXED":        "🔒",
    "FLOAT":        "🌊",
    "BOND":         "📄",
    "OPTION":       "⚙️",
    "EQUITY":       "📈",
    "CREDIT":       "🛡️",
    "EQUITY_OPTION":"🎯",
}
INSTRUMENT_ICONS = {
    "VanillaSwap":  "🔄",
    "Bond":         "📄",
    "Swaption":     "⚙️",
    "EquitySwap":   "📈",
    "CDS":          "🛡️",
    "EquityOption": "🎯",
}
FREQ_OPTIONS      = ["ANNUAL", "SEMIANNUAL", "QUARTERLY", "MONTHLY"]
DAY_COUNT_OPTIONS = ["30/360", "ACT/360", "ACT/ACT", "ACT/365"]

# ── page config ───────────────────────────────────────────────────────────────
st.set_page_config(
    page_title="Trade Manager",
    page_icon="📊",
    layout="wide",
    initial_sidebar_state="collapsed",
)

# ── CSS ───────────────────────────────────────────────────────────────────────
st.markdown("""
<style>
/* Tree node buttons */
div.tree-btn > div[data-testid="stButton"] > button {
    text-align: left;
    background: transparent;
    border: none;
    padding: 2px 4px;
    font-size: 0.80rem;
    width: 100%;
