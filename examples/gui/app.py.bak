}
/* Tighten expanders */
div[data-testid="stExpander"] summary {
    font-size: 0.82rem;
    padding: 4px 8px;
}
</style>
""", unsafe_allow_html=True)

# ── data helpers ──────────────────────────────────────────────────────────────

@st.cache_data(ttl=30)
def _load_all_trade_dicts() -> List[Dict[str, Any]]:
    repo = TradeRepository(DB_PATH)
    try:
        trades = repo.list_all()
        return [t._to_dict() for t in trades]
    finally:
        repo.close()


def _build_tree(trade_dicts: List[Dict]) -> Dict[str, Dict[str, List[Dict]]]:
    tree: Dict[str, Dict[str, List]] = {}
    for t in trade_dicts:
        trader = t.get("trader") or "(no trader)"
        book   = t.get("book")   or "(no book)"
        tree.setdefault(trader, {}).setdefault(book, []).append(t)
    return tree


def _fetch_trade_dict(trade_id: str) -> Optional[Dict]:
    repo = TradeRepository(DB_PATH)
    try:
        t = repo.get(trade_id)
        return t._to_dict() if t else None
    finally:
        repo.close()


def _save_trade_dict(trade_dict: Dict) -> bool:
    from models.trade_base import TradeBase
    try:
        trade = TradeBase.fromJson(json.dumps(trade_dict))
        repo  = TradeRepository(DB_PATH)
        try:
            repo.upsert(trade)
            return True
        finally:
            repo.close()
    except Exception as exc:
        st.error(f"Save failed: {exc}")
        return False


def _trades_to_df(trades: List[Dict]) -> pd.DataFrame:
    rows = []
    for t in trades:
        legs     = t.get("legs", [])
        notional = legs[0].get("notional", 0) if legs else 0
        rows.append({
            "trade_id":       t.get("trade_id", ""),
            "instrument":     t.get("trade_type", ""),
            "direction":      t.get("direction", ""),
            "counterparty":   t.get("counterparty", ""),
            "trader":         t.get("trader", ""),
            "valuation_date": t.get("valuation_date", ""),
            "notional":       float(notional),
            "n_legs":         len(legs),
        })
    if rows:
        return pd.DataFrame(rows)
    return pd.DataFrame(columns=["trade_id","instrument","direction","counterparty",
                                  "trader","valuation_date","notional","n_legs"])

# ── session state ─────────────────────────────────────────────────────────────

def _init_state() -> None:
    defaults = {
        "selected_trader":   None,
        "selected_book":     None,
        "selected_trade_id": None,
        "tree_open_traders": set(),
        "tree_open_books":   set(),   # set of (trader, book) tuples
    }
    for k, v in defaults.items():
        if k not in st.session_state:
            st.session_state[k] = v

_init_state()

# ── LEFT PANEL — tree ─────────────────────────────────────────────────────────

def _select_book(trader: str, book: str) -> None:
    st.session_state.selected_trader   = trader
    st.session_state.selected_book     = book
    st.session_state.selected_trade_id = None


def _select_trade(trade_id: str) -> None:
    st.session_state.selected_trade_id = trade_id


def render_tree(tree: Dict[str, Dict[str, List[Dict]]]) -> None:
    st.markdown('<div class="panel-header">🌳 Portfolio</div>', unsafe_allow_html=True)

    n_traders = len(tree)
    n_trades  = sum(len(v) for books in tree.values() for v in books.values())
    st.caption(f"{n_traders} traders · {n_trades:,} trades")

    sel_trader   = st.session_state.selected_trader
    sel_book     = st.session_state.selected_book
    sel_trade_id = st.session_state.selected_trade_id

    for trader in sorted(tree):
        books        = tree[trader]
        n_books      = len(books)
        n_tr         = sum(len(v) for v in books.values())
        is_open      = trader in st.session_state.tree_open_traders
        is_active    = (trader == sel_trader)

        # ── Trader row ────────────────────────────────────────────────────────
        arrow = "▼" if is_open else "▶"
        label = f"{arrow} 👤 {trader}  ({n_books} bks · {n_tr})"
        div_cls = "tree-btn-selected" if is_active else "tree-btn"
        st.markdown(f'<div class="{div_cls}">', unsafe_allow_html=True)
        if st.button(label, key=f"tr_{trader}", use_container_width=True):
            open_set = set(st.session_state.tree_open_traders)
            if is_open:
                open_set.discard(trader)
            else:
                open_set.add(trader)
                first_book = sorted(books)[0] if books else None
                if first_book:
                    _select_book(trader, first_book)
            st.session_state.tree_open_traders = open_set
            st.rerun()
        st.markdown('</div>', unsafe_allow_html=True)

        if not is_open:
            continue

        # ── Book rows ─────────────────────────────────────────────────────────
        for book in sorted(books):
            book_trades  = books[book]
            is_book_open = (trader, book) in st.session_state.tree_open_books
            is_book_sel  = (trader == sel_trader and book == sel_book)
            b_arrow      = "▼" if is_book_open else "▶"
            b_icon       = "📖" if is_book_sel else "📗"
            b_label      = f"  {b_arrow} {b_icon} {book}  ({len(book_trades)})"
            b_cls        = "tree-btn-selected" if is_book_sel else "tree-btn"

            st.markdown(f'<div class="{b_cls}">', unsafe_allow_html=True)
            if st.button(b_label, key=f"bk_{trader}_{book}", use_container_width=True):
                _select_book(trader, book)
                open_books = set(st.session_state.tree_open_books)
                if is_book_open:
                    open_books.discard((trader, book))
                else:
                    open_books.add((trader, book))
                st.session_state.tree_open_books = open_books
                st.rerun()
            st.markdown('</div>', unsafe_allow_html=True)

            if not is_book_open:
                continue

            # ── Trade rows ────────────────────────────────────────────────────
            shown = sorted(book_trades, key=lambda x: x.get("trade_id", ""))[:MAX_TRADES_IN_TREE]
            for td in shown:
                tid    = td.get("trade_id", "")
                ttype  = td.get("trade_type", "")
                t_icon = INSTRUMENT_ICONS.get(ttype, "📋")
                is_sel = (tid == sel_trade_id)
                t_cls  = "tree-btn-selected" if is_sel else "tree-btn"
                t_lbl  = f"    {'●' if is_sel else '○'} {t_icon} {tid}"

                st.markdown(f'<div class="{t_cls}">', unsafe_allow_html=True)
                if st.button(t_lbl, key=f"td_{tid}", use_container_width=True):
                    _select_trade(tid)
                    st.rerun()
                st.markdown('</div>', unsafe_allow_html=True)

            if len(book_trades) > MAX_TRADES_IN_TREE:
                st.caption(f"    … +{len(book_trades)-MAX_TRADES_IN_TREE} more (select in grid)")

# ── MIDDLE PANEL — editable grid ──────────────────────────────────────────────

def render_grid(trades: List[Dict]) -> None:
    trader = st.session_state.selected_trader
    book   = st.session_state.selected_book

    if not trader or not book:
        st.markdown('<div class="panel-header">📊 Trades</div>', unsafe_allow_html=True)
        st.info("← Select a book in the tree")
        return

    st.markdown(
        f'<div class="panel-header">📊 {book} — {trader}</div>',
        unsafe_allow_html=True,
    )

    if not trades:
        st.warning("No trades in this book.")
        return

    df = _trades_to_df(trades)

    gb = GridOptionsBuilder.from_dataframe(df)
    gb.configure_default_column(editable=True, resizable=True, sortable=True, filter=True, minWidth=80)
    gb.configure_column("trade_id",     editable=False, width=130, pinned="left")
    gb.configure_column("instrument",   editable=False, width=120)
    gb.configure_column("n_legs",       editable=False, width=70, headerName="Legs")
    gb.configure_column("notional",     type=["numericColumn","numberColumnFilter"],
                        width=125, valueFormatter="'$'+Math.round(value).toLocaleString()")
    gb.configure_column("direction",    width=115,
                        cellEditor="agSelectCellEditor",
                        cellEditorParams={"values": DIRECTIONS})
    gb.configure_column("valuation_date", width=130)
    gb.configure_column("counterparty",   width=120)
    gb.configure_column("trader",         width=80)
    gb.configure_selection("single", use_checkbox=False)
    gb.configure_grid_options(rowHeight=26, headerHeight=34, suppressMovableColumns=True)
    opts = gb.build()

    resp = AgGrid(
        df,
        gridOptions=opts,
        update_mode=GridUpdateMode.SELECTION_CHANGED,
        data_return_mode=DataReturnMode.AS_INPUT,
        fit_columns_on_grid_load=False,
        theme="streamlit",
        height=min(440, 96 + len(df) * 27),
        key=f"grid_{trader}_{book}",
        allow_unsafe_jscode=True,
        reload_data=False,
    )

    # ── handle row selection → right panel ───────────────────────────────────
    sel = resp.get("selected_rows")
    if sel is not None:
        # may be list[dict] or DataFrame
        if hasattr(sel, "to_dict"):            # DataFrame
            sel_list = sel.to_dict("records")
        else:
            sel_list = list(sel) if sel else []

        if sel_list:
            sel_id = sel_list[0].get("trade_id")
            if sel_id and sel_id != st.session_state.selected_trade_id:
                st.session_state.selected_trade_id = sel_id
                st.rerun()

    # ── bulk save ────────────────────────────────────────────────────────────
    if st.button("💾 Save Grid Changes", key=f"save_{trader}_{book}"):
        updated_df = resp["data"]
        if hasattr(updated_df, "iterrows"):
            ok, fail = 0, 0
            for _, row in updated_df.iterrows():
                tid = row["trade_id"]
                t   = _fetch_trade_dict(tid)
                if t:
                    t["direction"]      = str(row.get("direction", t["direction"]))
                    t["counterparty"]   = str(row.get("counterparty", t["counterparty"]))
                    t["trader"]         = str(row.get("trader", t["trader"]))
                    t["valuation_date"] = str(row.get("valuation_date", t["valuation_date"]))
                    try:
                        new_notional = float(row["notional"])
                        for leg in t.get("legs", []):
                            leg["notional"] = new_notional
                    except (ValueError, TypeError):
                        pass
                    if _save_trade_dict(t):
                        ok += 1
                    else:
                        fail += 1
            _load_all_trade_dicts.clear()
            if fail:
                st.warning(f"Saved {ok}, failed {fail}.")
            else:
                st.success(f"✅ Saved {ok} trades.")
            st.rerun()

# ── RIGHT PANEL — trade detail + leg editors ──────────────────────────────────

def render_trade_detail(trade_dict: Optional[Dict]) -> None:
    if not trade_dict:
        st.markdown('<div class="panel-header">📋 Trade Detail</div>', unsafe_allow_html=True)
        st.info("← Click a trade in the tree or grid")
        return

    trade_id   = trade_dict.get("trade_id", "")
    instrument = trade_dict.get("trade_type", "")
    icon       = INSTRUMENT_ICONS.get(instrument, "📋")

    st.markdown(
        f'<div class="panel-header">{icon} {trade_id} — {instrument}</div>',
        unsafe_allow_html=True,
    )

    with st.form(key=f"form_{trade_id}"):
        st.markdown("**📋 Trade Header**")
        c1, c2, c3 = st.columns(3)

        dir_val   = trade_dict.get("direction", DIRECTIONS[0])
        direction = c1.selectbox("Direction", DIRECTIONS,
                                 index=DIRECTIONS.index(dir_val) if dir_val in DIRECTIONS else 0)
        counterparty = c2.text_input("Counterparty", value=trade_dict.get("counterparty", ""))
        trader       = c3.text_input("Trader",        value=trade_dict.get("trader", ""))

        c4, c5 = st.columns(2)
        book         = c4.text_input("Book", value=trade_dict.get("book", ""))
        val_date     = _parse_date(trade_dict.get("valuation_date"))
        val_date_out = c5.date_input("Valuation Date", value=val_date)

        st.divider()
        st.markdown("**🦵 Legs**")

        legs_data = trade_dict.get("legs", [])
        new_legs: List[Dict] = []

        for i, leg in enumerate(legs_data):
            leg_type = leg.get("leg_type", "FIXED")
            leg_icon = LEG_ICONS.get(leg_type, "📌")
            with st.expander(f"{leg_icon} Leg {i+1} — {leg_type}", expanded=True):
                new_legs.append(_render_leg_fields(leg, i, trade_id))

        submitted = st.form_submit_button("💾 Save Trade", type="primary", use_container_width=True)

    if submitted:
        updated = dict(trade_dict)
        updated["direction"]      = direction
        updated["counterparty"]   = counterparty
        updated["trader"]         = trader
        updated["book"]           = book
        updated["valuation_date"] = val_date_out.isoformat()
        updated["legs"]           = new_legs
        if _save_trade_dict(updated):
            _load_all_trade_dicts.clear()
            st.success("✅ Trade saved!")
            st.rerun()


# ── leg field renderers ───────────────────────────────────────────────────────

def _parse_date(v: Any) -> date:
    try:
        return date.fromisoformat(str(v))
    except Exception:
        return date.today()


def _render_leg_fields(leg: Dict, idx: int, trade_id: str) -> Dict:
    out      = dict(leg)
    leg_type = leg.get("leg_type", "FIXED")
    pk       = f"{trade_id}_{idx}"

    # Common fields
    c1, c2, c3 = st.columns(3)
    out["notional"] = c1.number_input("Notional", value=float(leg.get("notional", 0)),
                                      min_value=0.0, step=100_000.0, format="%.0f", key=f"not_{pk}")
    out["start_date"] = str(c2.date_input("Start", value=_parse_date(leg.get("start_date")), key=f"sd_{pk}"))
    out["end_date"]   = str(c3.date_input("End",   value=_parse_date(leg.get("end_date")),   key=f"ed_{pk}"))

    c4, c5, c6 = st.columns(3)
    out["currency"]  = c4.text_input("Currency", value=leg.get("currency","USD"), key=f"ccy_{pk}")
    freq = leg.get("frequency","SEMIANNUAL")
    out["frequency"] = c5.selectbox("Frequency", FREQ_OPTIONS,
                                    index=FREQ_OPTIONS.index(freq) if freq in FREQ_OPTIONS else 1, key=f"frq_{pk}")
    dc = leg.get("day_count","30/360")
    out["day_count"] = c6.selectbox("Day Count", DAY_COUNT_OPTIONS,
                                    index=DAY_COUNT_OPTIONS.index(dc) if dc in DAY_COUNT_OPTIONS else 0, key=f"dc_{pk}")

    # Type-specific
    if leg_type == "FIXED":
        out["coupon_rate"] = st.number_input("Coupon Rate (%)",
            value=float(leg.get("coupon_rate",0))*100, min_value=0.0, max_value=50.0,
            step=0.01, format="%.4f", key=f"cr_{pk}") / 100

    elif leg_type == "FLOAT":
        f1, f2 = st.columns(2)
        out["spread"] = f1.number_input("Spread (bps)",
            value=float(leg.get("spread",0))*10_000, min_value=-500.0, max_value=500.0,
            step=0.5, format="%.2f", key=f"sprd_{pk}") / 10_000
        IDX = ["SOFR3M","SOFR1M","LIBOR3M","EURIBOR3M"]
        ix  = leg.get("index_name","SOFR3M")
        out["index_name"] = f2.selectbox("Index", IDX,
            index=IDX.index(ix) if ix in IDX else 0, key=f"idx_{pk}")

    elif leg_type == "BOND":
        b1, b2, b3 = st.columns(3)
        out["coupon_rate"]     = b1.number_input("Coupon (%)",
            value=float(leg.get("coupon_rate",0))*100, min_value=0.0, max_value=50.0,
            step=0.01, format="%.4f", key=f"cr_{pk}") / 100
        out["redemption"]      = b2.number_input("Redemption (%)",
            value=float(leg.get("redemption",100)), min_value=0.0, max_value=200.0,
            step=0.1, key=f"rdem_{pk}")
        out["settlement_days"] = int(b3.number_input("Settle Days",
            value=int(leg.get("settlement_days",2)), min_value=0, max_value=10, key=f"sett_{pk}"))

    elif leg_type == "OPTION":
        o1, o2, o3 = st.columns(3)
        out["strike"] = o1.number_input("Strike (%)",
            value=float(leg.get("strike",0.05))*100, min_value=0.0, max_value=50.0,
            step=0.01, format="%.4f", key=f"stk_{pk}") / 100
        OPT = ["PAYER_SWAPTION","RECEIVER_SWAPTION","CAP","FLOOR"]
        ot  = leg.get("option_type","PAYER_SWAPTION")
        out["option_type"] = o2.selectbox("Option Type", OPT,
            index=OPT.index(ot) if ot in OPT else 0, key=f"ot_{pk}")
        out["vol"] = o3.number_input("Vol (%)",
            value=float(leg.get("vol",0.4))*100, min_value=0.0, max_value=200.0,
            step=0.5, format="%.2f", key=f"vol_{pk}") / 100
        EX = ["EUROPEAN","AMERICAN","BERMUDAN"]
        ex = leg.get("exercise_type","EUROPEAN")
        out["exercise_type"] = st.selectbox("Exercise Type", EX,
            index=EX.index(ex) if ex in EX else 0, key=f"ext_{pk}")

    elif leg_type == "EQUITY":
        e1, e2 = st.columns(2)
        out["underlying_ticker"] = e1.text_input("Ticker",
            value=leg.get("underlying_ticker","SPY"), key=f"tick_{pk}")
        out["initial_price"] = e2.number_input("S0",
            value=float(leg.get("initial_price",100)), min_value=0.01, step=1.0, key=f"ip_{pk}")
        e3, e4 = st.columns(2)
        out["dividend_yield"] = e3.number_input("Div Yield (%)",
            value=float(leg.get("dividend_yield",0.015))*100, min_value=0.0, max_value=50.0,
            step=0.01, format="%.4f", key=f"dy_{pk}") / 100
        RT = ["TOTAL","PRICE","FUNDED"]
        rt = leg.get("equity_return_type","TOTAL")
        out["equity_return_type"] = e4.selectbox("Return Type", RT,
            index=RT.index(rt) if rt in RT else 0, key=f"rt_{pk}")

    elif leg_type == "CREDIT":
        cc1, cc2 = st.columns(2)
        out["reference_entity"] = cc1.text_input("Reference Entity",
            value=leg.get("reference_entity","CORP"), key=f"re_{pk}")
        out["credit_spread"] = cc2.number_input("Spread (bps)",
            value=float(leg.get("credit_spread",0.015))*10_000, min_value=0.0, max_value=5000.0,
            step=1.0, format="%.1f", key=f"cs_{pk}") / 10_000
        cc3, cc4 = st.columns(2)
        out["recovery_rate"] = cc3.number_input("Recovery (%)",
            value=float(leg.get("recovery_rate",0.40))*100, min_value=0.0, max_value=100.0,
            step=1.0, key=f"rr_{pk}") / 100
        SEN = ["SENIOR_UNSECURED","SUBORDINATED","SENIOR_SECURED"]
        sen = leg.get("seniority","SENIOR_UNSECURED")
        out["seniority"] = cc4.selectbox("Seniority", SEN,
            index=SEN.index(sen) if sen in SEN else 0, key=f"sen_{pk}")

    elif leg_type == "EQUITY_OPTION":
        eo1, eo2 = st.columns(2)
        out["underlying_ticker"] = eo1.text_input("Ticker",
            value=leg.get("underlying_ticker","SPY"), key=f"eotick_{pk}")
        out["initial_price"] = eo2.number_input("S0",
            value=float(leg.get("initial_price",100)), min_value=0.01, step=1.0, key=f"eoip_{pk}")
        eo3, eo4 = st.columns(2)
        out["strike"] = eo3.number_input("Strike",
            value=float(leg.get("strike",100)), min_value=0.01, step=1.0, key=f"eostk_{pk}")
        EO_OPT = ["CALL","PUT"]
        ot2 = leg.get("option_type","CALL")
        out["option_type"] = eo4.selectbox("Option Type", EO_OPT,
            index=EO_OPT.index(ot2) if ot2 in EO_OPT else 0, key=f"eoot_{pk}")
        eo5, eo6 = st.columns(2)
        out["vol"] = eo5.number_input("Vol (%)",
            value=float(leg.get("vol",0.25))*100, min_value=0.0, max_value=200.0,
            step=0.5, format="%.2f", key=f"eovol_{pk}") / 100
        out["dividend_yield"] = eo6.number_input("Div Yield (%)",
            value=float(leg.get("dividend_yield",0.013))*100, min_value=0.0, max_value=50.0,
            step=0.01, format="%.4f", key=f"eody_{pk}") / 100
        EX2 = ["EUROPEAN","AMERICAN"]
        ex2 = leg.get("exercise_type","EUROPEAN")
        out["exercise_type"] = st.selectbox("Exercise Type", EX2,
            index=EX2.index(ex2) if ex2 in EX2 else 0, key=f"eoext_{pk}")

    return out


# ── main ──────────────────────────────────────────────────────────────────────

def main() -> None:
    st.title("📊 Trade Manager")

    all_trades = _load_all_trade_dicts()
    tree       = _build_tree(all_trades)

    left_col, mid_col, right_col = st.columns([1, 2, 2], gap="small")

    with left_col:
        render_tree(tree)

    with mid_col:
        sel_trader  = st.session_state.selected_trader
        sel_book    = st.session_state.selected_book
        book_trades = (
            tree.get(sel_trader, {}).get(sel_book, [])
            if sel_trader and sel_book else []
        )
        render_grid(book_trades)

    with right_col:
        trade_id   = st.session_state.selected_trade_id
        trade_dict = _fetch_trade_dict(trade_id) if trade_id else None
        render_trade_detail(trade_dict)


if __name__ == "__main__":
    main()
